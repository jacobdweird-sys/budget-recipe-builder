# API Keys - Required for core features
# Get from: https://console.cloud.google.com/
GEMINI_API_KEY=your_google_gemini_api_key_here

# Public Gemini key (can be exposed to client)
NEXT_PUBLIC_GEMINI_API_KEY=your_public_gemini_api_key_here

# Spoonacular API - For pantry ingredient scanning
# Get from: https://spoonacular.com/food-api
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# Edamam API - For recipe database
# Get from: https://developer.edamam.com/
EDAMAM_APP_ID=your_edamam_app_id_here
EDAMAM_APP_KEY=your_edamam_api_key_here

# Environment
NODE_ENV=development

# Database - Required. Postgres connection string (e.g. Neon via Vercel Storage tab)
DATABASE_URL=your_postgres_connection_string_here

# Cookie settings
COOKIE_SECRET=your_secure_random_string_here
